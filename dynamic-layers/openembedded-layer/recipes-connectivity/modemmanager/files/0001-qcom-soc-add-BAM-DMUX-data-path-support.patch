+                (ctx->data_format_combination_i < 0)) {
                 g_assert (!ctx->dpm);
                 qmi_device_allocate_client (ctx->device,
                                             QMI_SERVICE_DPM,
@@ -1966,11 +2029,15 @@ internal_setup_data_format_context_step (GTask *task)
             /* Fall through */
 
